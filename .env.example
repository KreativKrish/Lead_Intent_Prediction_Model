# Environment - development, staging, or production
ENV=development

# Snowflake Configuration
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=LEAD_INTENT_DB
SNOWFLAKE_SCHEMA=FEATURES
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=ANALYST

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=lead_intent_prediction
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow/mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=./mlflow/artifacts

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info

# Model Configuration
MODEL_NAME=lead_intent_model
MODEL_STAGE=Production
MODEL_REGISTRY_URI=http://localhost:5000

# Training Configuration
TRAIN_TEST_SIZE=0.2
TRAIN_RANDOM_STATE=42
TRAIN_CV_FOLDS=5

# Airflow Configuration
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__DAGS_FOLDER=./dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Feature store
FEATURE_STORE_LOCATION=./feature_store

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
